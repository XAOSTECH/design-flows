#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════════
# 🎨 vscode-theme-gen — VS Code Theme Generator using Pastel
# ═══════════════════════════════════════════════════════════════════════════════
# Generates beautiful colour themes for VS Code workspace files.
# Uses pastel CLI for colour manipulation.
#
# Usage:
#   vsGen [OPTIONS]
#
# Examples:
#   vsGen --primary pink --secondary yellow -t lavender --name "Sakura"
#   vsGen -p "#ff69b4" -s "#ffd900" -t coral --compl --variation 0.7
#   vsGen --config workspace.code-workspace --primary coral
#   vsGen -p hotpink -s lime --dry-run -v          # preview only
#   vsGen -p coral -s gold -t skyblue              # auto-writes to ./out/
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

# ─── Resolve paths & source libraries ─────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib"

source "${LIB_DIR}/deps.sh"
source "${LIB_DIR}/colours.sh"
source "${LIB_DIR}/json-gen.sh"
source "${LIB_DIR}/file-ops.sh"
source "${LIB_DIR}/presets.sh"

# ─── Default Configuration ────────────────────────────────────────────────────
PRIMARY_COLOUR="pink"
SECONDARY_COLOUR="yellow"
TERTIARY_COLOUR="lavender"
THEME_NAME="Custom Theme"
USE_COMPLEMENTARY=false
OUTPUT_FILE=""
CONFIG_FILE=""
DRY_RUN=false
VERBOSE=false

# Background darkness level (0.0 = black, 1.0 = white)
BG_LIGHTNESS="0.12"

# Variation: 0 = no extra hues, 0.5 = standard, 1.0 = rainbow cacophony
VARIATION="0.5"

# ─── Colour Arrays (populated by generate_palette in colours.sh) ──────────────
declare -a PRIMARY_SHADES=()
declare -a SECONDARY_SHADES=()
declare -a TERTIARY_SHADES=()
declare -a COMPLEMENTARY_COLOURS=()
declare -a VARIATION_COLOURS=()
declare -a ANALOGOUS_COLOURS=()
declare -a TRIADIC_COLOURS=()
declare -a BLEND_COLOURS=()

# ─── Usage ────────────────────────────────────────────────────────────────────

print_usage() {
    cat << 'EOF'
🎨 vscode-theme-gen — VS Code Theme Generator

USAGE:
    vsGen [OPTIONS]

OPTIONS:
    -p, --primary <COLOUR>      Primary colour (name or hex).   Default: pink
    -s, --secondary <COLOUR>    Secondary colour (name or hex). Default: yellow
    -t, --tertiary <COLOUR>     Tertiary colour (name or hex).  Default: lavender
    -n, --name <NAME>          Theme name for comments.        Default: "Custom Theme"
    -o, --output <FILE>        Output workspace file path.
                               Default: ./out/<Name>-<date>-v<ver>.code-workspace
    -c, --config <FILE>        Existing workspace file to update (overwrites colours).
    --compl                    Generate complementary accent colours.
    --variation <0.0-1.0>      Colour variation level.         Default: 0.5
                                 0   = none (strict primary/secondary/tertiary)
                                 0.5 = standard variety
                                 1.0 = rainbow cacophony
    --bg-lightness <0.0-1.0>   Background darkness level.      Default: 0.12
    --preset <NAME>            Use a built-in colour preset.
    --list-presets             List available presets and exit.
    --dry-run                  Show generated colours without writing files.
    -v, --verbose              Show detailed colour generation info.
    -h, --help                 Show this help message.
    --version                  Print version and exit.

EXAMPLES:
    # Create a new theme with explicit output
    vsGen -p pink -s yellow -t lavender -o my-theme.code-workspace

    # Auto-output to ./out/ with defaults
    vsGen -p coral -s gold -t skyblue --compl

    # Use a preset
    vsGen --preset sakura

    # Update existing workspace with high variation
    vsGen -c project.code-workspace -p coral -s gold --variation 0.8

    # Preview a hotpink/lime/cyan theme
    vsGen -p hotpink -s lime -t cyan --dry-run -v

COLOUR VALUES:
    Named colours: pink, coral, gold, hotpink, lavender, skyblue, etc.
    Hex values:    "#ff69b4", "#ffd900", "#b0c4de"

PRESETS:
    sakura, ocean, forest, sunset, neon, nord, dracula, pastel
    Use --list-presets for details.

REQUIRES:
    pastel — command-line tool for colour manipulation
    Install: cargo install pastel
         or: see https://github.com/sharkdp/pastel/releases
EOF
}

# ─── Argument Parsing ─────────────────────────────────────────────────────────

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--primary)
                PRIMARY_COLOUR="$2"
                shift 2
                ;;
            -s|--secondary)
                SECONDARY_COLOUR="$2"
                shift 2
                ;;
            -t|--tertiary)
                TERTIARY_COLOUR="$2"
                shift 2
                ;;
            -n|--name)
                THEME_NAME="$2"
                shift 2
                ;;
            -o|--output)
                OUTPUT_FILE="$2"
                shift 2
                ;;
            -c|--config)
                CONFIG_FILE="$2"
                shift 2
                ;;
            --compl|--complementary)
                USE_COMPLEMENTARY=true
                shift
                ;;
            --variation)
                VARIATION="$2"
                # Clamp to [0, 1]
                VARIATION=$(awk "BEGIN { v=$VARIATION; if(v<0) v=0; if(v>1) v=1; printf \"%.2f\", v }")
                shift 2
                ;;
            --bg-lightness)
                BG_LIGHTNESS="$2"
                shift 2
                ;;
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            --preset)
                apply_preset "$2"
                shift 2
                ;;
            --list-presets)
                list_presets
                exit 0
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            --version)
                echo "vscode-theme-gen v${VSGEN_VERSION}"
                exit 0
                ;;
            -h|--help)
                print_usage
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                print_usage
                exit 1
                ;;
        esac
    done
}

# ─── Main ─────────────────────────────────────────────────────────────────────

main() {
    parse_args "$@"

    echo ""
    echo "  🎨 vscode-theme-gen v${VSGEN_VERSION}"
    echo "  ═══════════════════════════════════════"
    echo ""

    check_dependencies

    # Show configuration summary
    log_info "Theme:     ${THEME_NAME}"
    log_info "Primary:   ${PRIMARY_COLOUR}"
    log_info "Secondary: ${SECONDARY_COLOUR}"
    log_info "Tertiary:  ${TERTIARY_COLOUR}"
    log_info "Variation: ${VARIATION}"
    [[ "$USE_COMPLEMENTARY" == true ]] && log_info "Complementary: enabled"
    echo ""

    # Validate inputs
    if [[ -n "$CONFIG_FILE" ]] && [[ ! -f "$CONFIG_FILE" ]]; then
        log_error "Config file not found: $CONFIG_FILE"
        exit 1
    fi

    # Default output path when neither -o nor -c supplied (and not dry-run)
    if [[ -z "$OUTPUT_FILE" ]] && [[ -z "$CONFIG_FILE" ]] && [[ "$DRY_RUN" == false ]]; then
        OUTPUT_FILE=$(resolve_default_output)
        log_info "No output specified — defaulting to: $OUTPUT_FILE"
    fi

    # Generate palette
    generate_palette

    # Show preview
    show_palette_preview

    # Generate output
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Dry run — no files written"
        echo ""
        echo "Generated theme settings:"
        echo "─────────────────────────────────────────────────────────────"
        generate_theme_json
        echo ""
        echo "─────────────────────────────────────────────────────────────"
    elif [[ -n "$OUTPUT_FILE" ]]; then
        create_workspace_file "$OUTPUT_FILE"
    elif [[ -n "$CONFIG_FILE" ]]; then
        update_workspace_file "$CONFIG_FILE"
    fi

    echo ""
    log_success "Done!"
    echo ""
}

main "$@"
