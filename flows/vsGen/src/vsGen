# ─── File Operations ──────────────────────────────────────────────────────────

create_workspace_file() {
    local output="$1"
    local theme_settings
    theme_settings=$(generate_theme_json)
    
    cat << EOF > "$output"
{
	"folders": [
		{
			"path": "../"
		}
	],
	"settings": {
${theme_settings}
	}
}
EOF
    log_success "Created workspace file: $output"
}

update_workspace_file() {
    local config="$1"
    local theme_settings
    theme_settings=$(generate_theme_json)
    
    # Backup original
    cp "$config" "${config}.bak"
    log_verbose "Backup created: ${config}.bak"
    
    # Check if file has settings section
    if grep -q '"settings"' "$config"; then
        # Check if colorCustomizations exists
        if grep -q '"workbench.colorCustomizations"' "$config"; then
            # Complex replacement - use temp file approach
            local tmp_file=$(mktemp)
            
            # Use awk to replace the color customizations section
            awk -v theme="$theme_settings" '
            BEGIN { in_color_section = 0; in_token_section = 0; brace_count = 0 }
            
            /"workbench\.colorCustomizations"/ {
                in_color_section = 1
                brace_count = 0
                next
            }
            
            /"editor\.tokenColorCustomizations"/ && !in_color_section {
                in_token_section = 1
                brace_count = 0
                next
            }
            
            in_color_section {
                if (/{/) brace_count++
                if (/}/) {
                    brace_count--
                    if (brace_count <= 0) {
                        in_color_section = 0
                        print theme
                        if (/},/) print ","
                    }
                }
                next
            }
            
            in_token_section {
                if (/{/) brace_count++
                if (/}/) {
                    brace_count--
                    if (brace_count <= 0) {
                        in_token_section = 0
                    }
                }
                next
            }
            
            { print }
            ' "$config" > "$tmp_file"
            
            mv "$tmp_file" "$config"
            log_success "Updated color customizations in: $config"
        else
            # Insert colorCustomizations into settings
            # Find the settings object and insert after the opening brace
            local tmp_file=$(mktemp)
            
            awk -v theme="$theme_settings" '
            /"settings"[[:space:]]*:[[:space:]]*{/ {
                print
                getline
                print theme ","
                print
                next
            }
            { print }
            ' "$config" > "$tmp_file"
            
            mv "$tmp_file" "$config"
            log_success "Added color customizations to: $config"
        fi
    else
        # No settings section - add one
        local tmp_file=$(mktemp)
        
        # Find the last closing brace and insert settings before it
        awk -v theme="$theme_settings" '
        {
            if (/^}[[:space:]]*$/ && !done) {
                print "\t,\"settings\": {"
                print theme
                print "\t}"
                done = 1
            }
            print
        }
        ' "$config" > "$tmp_file"
        
        mv "$tmp_file" "$config"
        log_success "Added settings section to: $config"
    fi
}

show_palette_preview() {
    echo ""
    echo "═══════════════════════════════════════════════════════════"
    echo "  🎨 ${THEME_NAME} - Color Palette Preview"
    echo "═══════════════════════════════════════════════════════════"
    echo ""
    
    echo "  Primary: ${PRIMARY_COLOR}"
    echo "  ─────────────────────────────────────"
    for i in "${!PRIMARY_SHADES[@]}"; do
        local hex="${PRIMARY_SHADES[$i]}"
        # Print colored block using pastel
        printf "  "
        pastel paint "$hex" "████"
        printf " %s\n" "$hex"
    done
    
    echo ""
    echo "  Secondary: ${SECONDARY_COLOR}"
    echo "  ─────────────────────────────────────"
    for i in "${!SECONDARY_SHADES[@]}"; do
        local hex="${SECONDARY_SHADES[$i]}"
        printf "  "
        pastel paint "$hex" "████"
        printf " %s\n" "$hex"
    done
    
    if [[ "$USE_COMPLEMENTARY" == true ]] && [[ ${#COMPLEMENTARY_COLORS[@]} -gt 0 ]]; then
        echo ""
        echo "  Complementary Accents:"
        echo "  ─────────────────────────────────────"
        for i in "${!COMPLEMENTARY_COLORS[@]}"; do
            local hex="${COMPLEMENTARY_COLORS[$i]}"
            printf "  "
            pastel paint "$hex" "████"
            printf " %s\n" "$hex"
        done
    fi
    
    echo ""
    echo "═══════════════════════════════════════════════════════════"
    echo ""
}

# ─── Main ─────────────────────────────────────────────────────────────────────

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--primary)
                PRIMARY_COLOR="$2"
                shift 2
                ;;
            -s|--secondary)
                SECONDARY_COLOR="$2"
                shift 2
                ;;
            -n|--name)
                THEME_NAME="$2"
                shift 2
                ;;
            -o|--output)
                OUTPUT_FILE="$2"
                shift 2
                ;;
            -c|--config)
                CONFIG_FILE="$2"
                shift 2
                ;;
            --compl|--complementary)
                USE_COMPLEMENTARY=true
                shift
                ;;
            --bg-lightness)
                BG_LIGHTNESS="$2"
                shift 2
                ;;
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -h|--help)
                print_usage
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                print_usage
                exit 1
                ;;
        esac
    done
}

main() {
    parse_args "$@"
    
    echo ""
    echo "  🎨 vscode-theme-gen"
    echo "  ═══════════════════════════════════════"
    echo ""
    
    check_dependencies
    
    # Validate inputs
    if [[ -n "$CONFIG_FILE" ]] && [[ ! -f "$CONFIG_FILE" ]]; then
        log_error "Config file not found: $CONFIG_FILE"
        exit 1
    fi
    
    if [[ -z "$OUTPUT_FILE" ]] && [[ -z "$CONFIG_FILE" ]] && [[ "$DRY_RUN" == false ]]; then
        log_error "Either --output or --config must be specified (or use --dry-run)"
        exit 1
    fi
    
    # Generate palette
    generate_palette
    
    # Show preview (always show the color palette)
    show_palette_preview
    
    # Generate output
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Dry run - no files written"
        echo ""
        echo "Generated theme settings:"
        echo "─────────────────────────────────────────────────────────────"
        generate_theme_json
        echo ""
        echo "─────────────────────────────────────────────────────────────"
    elif [[ -n "$OUTPUT_FILE" ]]; then
        create_workspace_file "$OUTPUT_FILE"
    elif [[ -n "$CONFIG_FILE" ]]; then
        update_workspace_file "$CONFIG_FILE"
    fi
    
    echo ""
    log_success "Done!"
    echo ""
}

main "$@"
