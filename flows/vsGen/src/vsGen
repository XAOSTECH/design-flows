#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════════
# 🎨 vscode-theme-gen - VS Code Theme Generator using Pastel
# ═══════════════════════════════════════════════════════════════════════════════
# Generates beautiful color themes for VS Code workspace files
# Uses pastel CLI for color manipulation
#
# Usage:
#   vscode-theme-gen [OPTIONS]
#
# Examples:
#   vscode-theme-gen --primary pink --secondary yellow --name "Sakura"
#   vscode-theme-gen -p "#ff69b4" -s "#ffd900" --compl --output theme.json
#   vscode-theme-gen --config workspace.code-workspace --primary coral
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

# ─── Default Configuration ────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATE_DIR="${SCRIPT_DIR}/templates"

# Default colors
PRIMARY_COLOR="pink"
SECONDARY_COLOR="yellow"
THEME_NAME="Custom Theme"
USE_COMPLEMENTARY=false
OUTPUT_FILE=""
CONFIG_FILE=""
DRY_RUN=false
VERBOSE=false

# Background darkness level (0.0 = black, 1.0 = white)
BG_LIGHTNESS="0.12"

# ─── Color Arrays (populated by generate_palette) ─────────────────────────────
declare -a PRIMARY_SHADES=()
declare -a SECONDARY_SHADES=()
declare -a COMPLEMENTARY_COLORS=()

# ─── Helper Functions ─────────────────────────────────────────────────────────

print_usage() {
    cat << 'EOF'
🎨 vscode-theme-gen - VS Code Theme Generator

USAGE:
    vscode-theme-gen [OPTIONS]

OPTIONS:
    -p, --primary <COLOR>      Primary color (name or hex). Default: pink
    -s, --secondary <COLOR>    Secondary color (name or hex). Default: yellow
    -n, --name <NAME>          Theme name for comments. Default: "Custom Theme"
    -o, --output <FILE>        Output file path (creates new workspace file)
    -c, --config <FILE>        Existing workspace file to update (overwrites colors)
    --compl                    Generate complementary colors for variety
    --bg-lightness <0.0-1.0>   Background darkness level. Default: 0.12
    --dry-run                  Show generated colors without writing
    -v, --verbose              Show detailed color generation info
    -h, --help                 Show this help message

EXAMPLES:
    # Create new theme with pink and yellow
    vscode-theme-gen -p pink -s yellow -o my-theme.code-workspace

    # Update existing workspace with coral theme + complementary
    vscode-theme-gen -c project.code-workspace -p coral -s gold --compl

    # Preview a hotpink/lime theme
    vscode-theme-gen -p hotpink -s lime --dry-run -v

COLOR VALUES:
    Colors can be specified as:
    - Named colors: pink, coral, gold, hotpink, lavender, etc.
    - Hex values: "#ff69b4", "#ffd900"

REQUIRES:
    pastel - Command-line tool for color manipulation
    Install: cargo install pastel
         or: wget pre-built binary from https://github.com/sharkdp/pastel/releases
EOF
}

log_verbose() {
    if [[ "$VERBOSE" == true ]]; then
        echo -e "  \033[0;90m$1\033[0m"
    fi
}

log_info() {
    echo -e "  \033[0;36m→\033[0m $1"
}

log_success() {
    echo -e "  \033[0;32m✓\033[0m $1"
}

log_error() {
    echo -e "  \033[0;31m✗\033[0m $1" >&2
}

check_dependencies() {
    if ! command -v pastel &> /dev/null; then
        log_error "pastel is not installed"
        echo ""
        echo "Install with one of:"
        echo "  cargo install pastel"
        echo "  wget -qO- https://github.com/sharkdp/pastel/releases/download/v0.9.0/pastel-v0.9.0-x86_64-unknown-linux-musl.tar.gz | tar xz"
        exit 1
    fi
}

# ─── Color Generation Functions ───────────────────────────────────────────────

# Get hex color from pastel
get_hex() {
    pastel format hex "$1" 2>/dev/null | tr -d '\n'
}

# Generate gradient shades
generate_gradient() {
    local from="$1"
    local to="$2"
    local count="${3:-6}"
    pastel gradient -n "$count" "$from" "$to" | pastel format hex
}

# Mix two colors
mix_colors() {
    local color1="$1"
    local color2="$2"
    local factor="${3:-0.5}"
    pastel mix -f "$factor" "$color1" "$color2" | pastel format hex
}

# Lighten a color
lighten() {
    local color="$1"
    local amount="${2:-0.1}"
    pastel lighten "$amount" "$color" | pastel format hex
}

# Darken a color
darken() {
    local color="$1"
    local amount="${2:-0.1}"
    pastel darken "$amount" "$color" | pastel format hex
}

# Set lightness
set_lightness() {
    local color="$1"
    local lightness="$2"
    pastel set lightness "$lightness" "$color" | pastel format hex
}

# Get complementary color
get_complementary() {
    local color="$1"
    pastel complement "$color" | pastel format hex
}

# Saturate color
saturate() {
    local color="$1"
    local amount="${2:-0.2}"
    pastel saturate "$amount" "$color" | pastel format hex
}

# Desaturate color
desaturate() {
    local color="$1"
    local amount="${2:-0.2}"
    pastel desaturate "$amount" "$color" | pastel format hex
}

# Generate the full color palette
generate_palette() {
    log_info "Generating color palette..."
    
    # Get base colors
    local primary_hex=$(get_hex "$PRIMARY_COLOR")
    local secondary_hex=$(get_hex "$SECONDARY_COLOR")
    
    log_verbose "Primary base: $primary_hex"
    log_verbose "Secondary base: $secondary_hex"
    
    # Generate primary shades (dark to light)
    log_verbose "Generating primary gradient..."
    local primary_bright=$(saturate "$PRIMARY_COLOR" 0.2)
    local primary_soft=$(lighten "$PRIMARY_COLOR" 0.15)
    
    mapfile -t PRIMARY_SHADES < <(generate_gradient "$primary_bright" "$primary_soft" 6)
    
    # Generate secondary shades
    log_verbose "Generating secondary gradient..."
    local secondary_bright=$(saturate "$SECONDARY_COLOR" 0.2)
    local secondary_soft=$(lighten "$SECONDARY_COLOR" 0.2)
    
    mapfile -t SECONDARY_SHADES < <(generate_gradient "$secondary_bright" "$secondary_soft" 6)
    
    # Generate complementary colors if requested
    if [[ "$USE_COMPLEMENTARY" == true ]]; then
        log_verbose "Generating complementary colors..."
        local compl_primary=$(get_complementary "$PRIMARY_COLOR")
        local compl_secondary=$(get_complementary "$SECONDARY_COLOR")
        local mixed=$(mix_colors "$PRIMARY_COLOR" "$SECONDARY_COLOR" 0.5)
        
        COMPLEMENTARY_COLORS=(
            "$compl_primary"
            "$compl_secondary"
            "$(lighten "$compl_primary" 0.2)"
            "$(lighten "$compl_secondary" 0.2)"
            "$mixed"
            "$(get_complementary "$mixed")"
        )
    fi
    
    log_success "Palette generated"
}

# ─── Theme Generation ─────────────────────────────────────────────────────────

